---
export interface Props {
  platform: string;
  username: string;
}

const { platform, username } = Astro.props;
---

<a href={`https://www.${platform}.com/${username}`}>{platform}</a>
<style>
  a {
    padding: 0.25rem 0.5rem;
    color: rgb(45, 212, 191);
    background-color: transparent;
    text-decoration: none;
  }
</style>

