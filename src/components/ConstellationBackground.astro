<canvas id="constellation" class="fixed inset-0 pointer-events-none z-0"></canvas>

<script>
  const canvas = document.getElementById('constellation') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d') as CanvasRenderingContext2D;
  
  let width: number, height: number;
  let points: { x: number, y: number, vx: number, vy: number, size: number }[] = [];
  const POINT_COUNT = 50;
  const CONNECTION_DISTANCE = 160;
  const LINE_OPACITY = 0.8;

  function resize() {
    width = canvas.width = window.innerWidth;
    height = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  for (let i = 0; i < POINT_COUNT; i++) {
    points.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      vx: (Math.random() - 0.5) * 0.5,
      vy: (Math.random() - 0.5) * 0.5,
      size: Math.random() * 2 + 1
    });
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    points.forEach((p, i) => {
      p.x += p.vx;
      p.y += p.vy;
      
      if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
      if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
      
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(20, 184, 166, 0.8)';
      ctx.fill();
      
      points.slice(i + 1).forEach(p2 => {
        const dx = p.x - p2.x;
        const dy = p.y - p2.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        
        if (dist < CONNECTION_DISTANCE) {
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(p2.x, p2.y);
          ctx.strokeStyle = `rgba(20, 184, 166, ${LINE_OPACITY * (1 - dist / CONNECTION_DISTANCE)})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      });
    });
    
    requestAnimationFrame(draw);
  }
  
  if (!document.hidden) draw();
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) draw();
  });
</script>