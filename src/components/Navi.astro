---
import PagefindSearch from 'astro-pagefind/components/Search';
---

<nav class="bg-linear-to-b from-zinc-700 to-zinc-900 shadow-lg fixed top-0 left-0 right-0 sm:left-0 sm:right-0 md:left-0 md:right-0 z-50">
  <!-- 导航栏部分保持不变 ... -->
  <div class="container mx-auto px-4 sm:px-6 md:px-8 py-2">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-4 sm:space-x-6 md:space-x-10 lg:space-x-16 xl:space-x-24">
        <div class="flex items-center space-x-0 md:space-x-1 lg:space-x-2">
          <div class="w-8 h-8 flex items-center justify-center">
            <img src="/favicon.svg" alt="Mped" class="w-6 h-6" width="24" height="24" loading="eager" />
          </div>
            <!-- ✅ 有效 HTML -->
            <a href="/" class="text-xl tracking-wider bg-clip-text text-transparent hover:text-white transition-colors">
              <span class="text-red-500">M</span><span class="text-sky-500">p</span><span class="text-lime-500">e</span><span class="text-yellow-300">d</span>
            </a>        
          </div>

        <div class="hidden md:flex space-x-2">
          <a href="/" class="tracking-wider text-sm font-medium text-teal-300 hover:text-white hover:scale-110 transition-all duration-300 px-4 py-2 rounded-lg relative group">主页<span class="absolute bottom-0 left-1/2 w-0 h-px bg-current transition-all duration-300 group-hover:w-3/5 group-hover:left-1/5 transform -translate-x-1/2 group-hover:translate-x-0"></span></a>
          <a href="/blog/" class="tracking-wider text-sm font-medium text-teal-300 hover:text-white hover:scale-110 transition-all duration-300 px-4 py-2 rounded-lg relative group">博客<span class="absolute bottom-0 left-1/2 w-0 h-px bg-current transition-all duration-300 group-hover:w-3/5 group-hover:left-1/5 transform -translate-x-1/2 group-hover:translate-x-0"></span></a>   
          <a href="/software/" class="tracking-wider text-sm font-medium text-teal-300 hover:text-white hover:scale-110 transition-all duration-300 px-4 py-2 rounded-lg relative group">软件<span class="absolute bottom-0 left-1/2 w-0 h-px bg-current transition-all duration-300 group-hover:w-3/5 group-hover:left-1/5 transform -translate-x-1/2 group-hover:translate-x-0"></span></a>
          <a href="/system/" class="tracking-wider text-sm font-medium text-teal-300 hover:text-white hover:scale-110 transition-all duration-300 px-4 py-2 rounded-lg relative group">系统<span class="absolute bottom-0 left-1/2 w-0 h-px bg-current transition-all duration-300 group-hover:w-3/5 group-hover:left-1/5 transform -translate-x-1/2 group-hover:translate-x-0"></span></a>
          <a href="/game/" class="tracking-wider text-sm font-medium text-teal-300 hover:text-white hover:scale-110 transition-all duration-300 px-4 py-2 rounded-lg relative group">游戏<span class="absolute bottom-0 left-1/2 w-0 h-px bg-current transition-all duration-300 group-hover:w-3/5 group-hover:left-1/5 transform -translate-x-1/2 group-hover:translate-x-0"></span></a>
          <a href="/link/" class="tracking-wider text-sm font-medium text-teal-300 hover:text-white hover:scale-110 transition-all duration-300 px-4 py-2 rounded-lg relative group">导航<span class="absolute bottom-0 left-1/2 w-0 h-px bg-current transition-all duration-300 group-hover:w-3/5 group-hover:left-1/5 transform -translate-x-1/2 group-hover:translate-x-0"></span></a>
        </div>
      </div>

      <div class="flex items-center space-x-4">
        <button id="search-toggle" class="p-2 text-teal-400 hover:text-white hover:bg-zinc-800 rounded-lg transition-all duration-300 hover:scale-110 active:scale-95">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>

        <details data-hamburger class="md:hidden relative">
          <summary class="list-none cursor-pointer p-2 text-gray-300 hover:text-white hover:bg-zinc-800 rounded-lg transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </summary>
          <div class="absolute right-0 top-full mt-2 w-48 bg-zinc-800 rounded-lg shadow-xl z-50 overflow-hidden">
            <a href="/" class="block px-4 py-3 text-teal-300 hover:text-white hover:bg-zinc-700 transition-colors border-l-4 border-transparent hover:border-teal-400">主页</a>
            <a href="/blog/" class="block px-4 py-3 text-teal-300 hover:text-white hover:bg-zinc-700 transition-colors border-l-4 border-transparent hover:border-teal-400">博客</a>
            <a href="/software/" class="block px-4 py-3 text-teal-300 hover:text-white hover:bg-zinc-700 transition-colors border-l-4 border-transparent hover:border-teal-400">软件</a>
            <a href="/system/" class="block px-4 py-3 text-teal-300 hover:text-white hover:bg-zinc-700 transition-colors border-l-4 border-transparent hover:border-teal-400">系统</a>  
            <a href="/game/" class="block px-4 py-3 text-teal-300 hover:text-white hover:bg-zinc-700 transition-colors border-l-4 border-transparent hover:border-teal-400">游戏</a>
            <a href="/link/" class="block px-4 py-3 text-teal-300 hover:text-white hover:bg-zinc-700 transition-colors border-l-4 border-transparent hover:border-teal-400">导航</a>
          </div>
        </details>
      </div>
    </div>
  </div>
</nav>

<!-- 搜索模态框 -->
<div id="search-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black bg-opacity-70" id="search-modal-overlay"></div>
  <!-- 外层容器：用于居中 -->
  <div class="relative flex items-start justify-center min-h-screen pt-20 p-4">
    
    <!-- 内层容器：设置固定最大高度和滚动 -->
    <div class="bg-zinc-900 rounded-xl shadow-2xl w-full max-w-2xl max-h-[80vh] flex flex-col overflow-hidden border border-zinc-700">
      
      <!-- 头部：固定不动 -->
      <div class="flex items-center justify-between p-4 border-b border-zinc-700 shrink-0">
        <h3 class="text-lg font-bold text-teal-400">搜索网站内容</h3>
        <button id="search-close" class="p-2 text-gray-400 hover:text-white hover:bg-zinc-800 rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      
      <!-- 内容区：可滚动 -->
      <div class="p-4 overflow-y-auto grow">
        <PagefindSearch 
          className="pagefind-search" 
          uiOptions={{ 
            showImages: false,
            translations: {
              placeholder: '输入关键词搜索...',
              zero_results: '没有找到相关内容'
            }
          }} 
        />
      </div>
    </div>
  </div>
</div>

<script>
  function initSearch() {
    const searchToggle = document.getElementById('search-toggle');
    const searchModal = document.getElementById('search-modal');
    const searchClose = document.getElementById('search-close');
    const searchModalOverlay = document.getElementById('search-modal-overlay');

    if (searchToggle && searchModal && searchClose && searchModalOverlay) {
      searchToggle.addEventListener('click', () => {
        searchModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });

      const closeModal = () => {
        searchModal.classList.add('hidden');
        document.body.style.overflow = '';
      };

      searchClose.addEventListener('click', closeModal);
      searchModalOverlay.addEventListener('click', closeModal);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !searchModal.classList.contains('hidden')) {
          closeModal();
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initSearch);

  document.addEventListener('click', (e) => {
    const details = document.querySelector('details[data-hamburger]');
    const target = e.target as Node | null;
    if (details && target && !details.contains(target)) {
      details.removeAttribute('open');
    }
  });
</script>

<style is:global>
  /* Pagefind UI CSS 变量配置 */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-text: #f9fafb;
    --pagefind-ui-background: #18181b; /* 结果背景色，稍微深一点以区分 */
    --pagefind-ui-border: #374151;
    --pagefind-ui-primary: #14b8a6;
    --pagefind-ui-secondary: #9ca3af;
    --pagefind-ui-tag: #374151;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: inherit;
    --pagefind-ui-max-height: 50vh; 

        /* 1. 卡片间距与内边距 */
    .pagefind-search .pagefind-ui__result {
      padding: 0.5rem;       /* 减小内边距 */
      margin-bottom: 0.1rem;  /* 减小下边距 */
    }
      /* 2. 标题 */
    .pagefind-search .pagefind-ui__result-title {
      font-size: 1.25rem;        /* 调整字体大小 */
      line-height: 1.2;
    }
    .result-title {
    text-align: center;
    }
  }

  .pagefind-search {
    width: 100%;
  }
  
  /* 确保结果容器本身也能正确处理滚动 */
  .pagefind-search > :first-child {
    height: 100%;
  }
</style>
