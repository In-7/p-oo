---
// src/components/CategoryFilter.astro

export interface Props {
  categories: string[];
  selectedCategory?: string;
  baseUrl: string;
}

const { 
  categories, 
  selectedCategory,
  baseUrl 
} = Astro.props;

const toSlug = (str: string): string => {
  return str
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\w\u4e00-\u9fa5-]/g, '');
};

// 判断是否为选中状态
const isSelected = (category: string): boolean => {
  if (!selectedCategory) return category === "全部";
  return selectedCategory === category;
};
---

<nav class="flex flex-wrap gap-2 mb-6">
  <a 
    href={baseUrl}
    class={`px-3 py-1 rounded-full text-sm transition-colors duration-200 whitespace-nowrap border ${
      !selectedCategory
        ? 'bg-teal-500 text-white border-teal-500' 
        : 'bg-zinc-800 text-gray-400 border-zinc-700 hover:border-teal-500/50 hover:bg-zinc-700 hover:text-white'
    }`}
  >
    全部
  </a>
  
  {categories.map(category => (
    <a 
      href={`${baseUrl}/${toSlug(category)}`}
      class={`px-3 py-1 rounded-full text-sm transition-colors duration-200 whitespace-nowrap border ${
        isSelected(category)
          ? 'bg-teal-500 text-white border-teal-500' 
          : 'bg-zinc-800 text-gray-300 border-zinc-700 hover:border-teal-500/50 hover:bg-zinc-700 hover:text-white'
      }`}
    >
      {category}
    </a>
  ))}
</nav>
