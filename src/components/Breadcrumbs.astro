---
// src/components/Breadcrumbs.astro
// 面包屑导航组件 - 支持 Content Collections + 动态路由

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
  currentPage?: string;
}

const { items, currentPage } = Astro.props;
---

<nav class="sr-only" aria-label="Breadcrumb">
  <ol class="flex items-center space-x-2 list-none p-0 m-0">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && (
          <svg class="w-4 h-4 mx-2 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        )}
        
        {item.href ? (
          <a 
            href={item.href} 
            class="hover:text-teal-400 transition-colors duration-200"
          >
            {item.label}
          </a>
        ) : (
          <span>{item.label}</span>
        )}
      </li>
    ))}
    
    {currentPage && (
      <>
        <svg class="w-4 h-4 mx-2 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
        <span class="text-teal-400 font-semibold">{currentPage}</span>
      </>
    )}
  </ol>
</nav>
