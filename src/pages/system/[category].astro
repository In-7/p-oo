---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CategoryFilter from "../../components/CategoryFilter.astro";
import PerformanceOptimizer from "../../components/PerformanceOptimizer.astro";
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const systemItems: CollectionEntry<'system'>[] = await getCollection('system');
  const categories: string[] = [...new Set(systemItems.map(item => item.data.category))];

  return categories.map(category => {
    const slug = category.toLowerCase().replace(/\s+/g, '-');
    const filteredSystem: CollectionEntry<'system'>[] = systemItems.filter(item => item.data.category === category);

    return {
      params: { category: slug },
      props: {
        category,
        filteredSystem,
        allCategories: categories
      }
    };
  });
}

const { category, filteredSystem, allCategories } = Astro.props;

const getColor = (name: string) => `hsl(${name.charCodeAt(0) * 15 % 360}, 70%, 50%)`;

const breadcrumbItems = [
  { label: '主页', href: '/' },
  { label: '操作系统', href: '/system' },
  { label: category }
];
---

<BaseLayout title={`${category} - Mped 的个人网站`} description={`浏览${category}操作系统。`}>
  <Navi />

  <main data-pagefind-body class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} currentPage={category} />

      <div class="bg-transparent rounded-lg p-4 mb-4">
        <CategoryFilter categories={allCategories} selectedCategory={category} baseUrl="/system" />
      </div>

      <div class="flex justify-between items-center mb-6">
        <p class="text-gray-400 whitespace-nowrap">
          找到 <span class="text-teal-200 font-semibold">{filteredSystem.length}</span> 个系统
        </p>
        <p class="text-gray-400 text-sm whitespace-nowrap">
          当前分类：<span class="text-teal-200">{category}</span>
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {filteredSystem.map(system => (
          <a
            href={`/system/${system.id}`}
            class="system-card bg-zinc-800 rounded-xl p-3 hover:scale-105 hover:shadow-2xl transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <div class="flex items-center mb-4">
                <div
                  class="w-20 h-10 rounded-lg flex items-center justify-center"
                  style={`background-color: ${system.data.color || getColor(system.data.name)};`}
                >
                  <span class="text-white font-bold text-xl">{system.data.icon}</span>
                </div>
                <div class="ml-8">
                  <h3 class="text-base font-bold text-white hover:text-teal-200 transition-colors">{system.data.name}</h3>
                  <span class="text-sm text-gray-400">{system.data.category}</span>
                </div>
              </div>
              <p class="text-gray-300 text-xs grow mb-4 leading-relaxed">{system.data.description}</p>
              <div class="flex justify-between text-xs text-gray-400">
                <span class="bg-zinc-700 px-2 py-1 rounded">v{system.data.version}</span>
                <span>{system.data.architecture}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/system" class="inline-block px-8 py-3 bg-teal-500 text-white font-semibold rounded-lg hover:bg-teal-400 transition-colors">
          返回全部系统
        </a>
      </div>
    </div>
  </main>

  <Footer />
  <PerformanceOptimizer />
</BaseLayout>
