---
import "../../styles/global.css";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CategoryFilter from "../../components/CategoryFilter.astro";
import PerformanceOptimizer from "../../components/PerformanceOptimizer.astro";
import { getCollection } from 'astro:content';

const systemItems = await getCollection('system');
const categories = [...new Set(systemItems.map(item => item.data.category))];

const breadcrumbItems = [
  { label: '主页', href: '/' },
  { label: '操作系统' }
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content="浏览各种操作系统，包括 Windows、Linux、macOS 等。" />
  <meta name="author" content="Mped" />
  <link rel="icon" href="/favicon.png" />
  <title>操作系统 - Mped 的个人网站</title>
</head>

<body class="flex flex-col min-h-screen">
  <Navi />

  <main class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} />


      <div class="bg-zinc-900 rounded-lg p-4 mb-4">
        <!-- <h2 class="text-xl font-semibold text-teal-400 mb-4">分类筛选</h2> -->
        <CategoryFilter categories={categories} baseUrl="/system" />
      </div>

      <div class="flex justify-between items-center mb-6">
        <p class="text-gray-400 whitespace-nowrap">
          找到 <span class="text-teal-400 font-semibold">{systemItems.length}</span> 个系统
        </p>
        <p class="text-gray-400 text-sm whitespace-nowrap">
          当前分类：<span class="text-teal-400">全部</span>
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {systemItems.map(system => (
          <a 
            href={`/system/${system.id}`}
            class="system-card bg-zinc-800 rounded-xl p-3 hover:scale-105 hover:shadow-2xl transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <div class="flex items-center mb-4">
                <div 
                  class="w-20 h-10 rounded-lg flex items-center justify-center"
                  style={`background-color: ${system.data.color};`}
                >
                  <span class="text-white font-bold text-xl">{system.data.icon}</span>
                </div>
                <div class="ml-8">
                  <h3 class="text-base font-bold text-white hover:text-teal-300 transition-colors">{system.data.name}</h3>
                  <span class="text-sm text-gray-400">{system.data.category}</span>
                </div>
              </div>
              <span class="text-gray-300 text-xs flex-grow mb-2 leading-relaxed">{system.data.description}</span>
              <div class="flex justify-between text-xs text-gray-400">
                <span class="bg-zinc-700 px-2 py-1 rounded">v{system.data.version}</span>
                <span>{system.data.architecture}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
  <PerformanceOptimizer />
</body>
</html>
