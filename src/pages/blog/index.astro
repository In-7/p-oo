---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PerformanceOptimizer from "../../components/PerformanceOptimizer.astro";
import { getCollection, type CollectionEntry } from 'astro:content';

const blogItems: CollectionEntry<'blog'>[] = await getCollection('blog');
const sortedPosts: CollectionEntry<'blog'>[] = blogItems.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbItems = [
  { label: '主页', href: '/' },
  { label: '博客' }
];
---

<BaseLayout title="博客 - Mped 的个人网站" description="浏览我的博客文章，涵盖 Astro 学习、Web 开发、个人成长等话题。">
  <Navi />

  <main class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} />

      <div class="flex justify-between items-center mb-2">
        <p class="text-gray-400 whitespace-nowrap">
          共 <span class="text-teal-400 font-semibold">{sortedPosts.length}</span> 篇文章
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        {sortedPosts.map(post => (
          <a
            href={`/blog/${post.id}`}
            class="bg-zinc-800 rounded-xl p-4 hover:scale-105 hover:shadow-2xl cursor-pointer block transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <h3 class="text-sm font-bold text-white mb-3 hover:text-teal-300 transition-colors">
                {post.data.title}
              </h3>

              <span class="text-gray-300 text-xs grow mb-4 leading-relaxed">
                {post.data.description}
              </span>

              <div class="flex justify-between items-center text-xs text-gray-400">
                <span>{post.data.author || 'Mped'}</span>
                <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
              </div>

              <div class="flex justify-between items-center mt-2">
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag: string) => (
                      <span class="px-2 py-1 bg-zinc-700 text-gray-300 text-xs rounded">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
                <span class="px-2 py-1 bg-purple-500 text-white text-xs font-medium rounded-full">
                  {post.data.category}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
  <PerformanceOptimizer />
</BaseLayout>
