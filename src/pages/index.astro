---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navi from "../components/Navi.astro";
import Footer from "../components/Footer.astro";
import SearchBox from "../components/SearchBox.astro";
import PerformanceOptimizer from "../components/PerformanceOptimizer.astro";
import ConstellationBackground from "../components/ConstellationBackground.astro";
---

<BaseLayout title="Mped的个人网站 - 技术博客与创作分享" description="分享技术心得、生活感悟和创作内容。专注于前端开发、Astro框架和现代Web技术。">
  <ConstellationBackground />
  <Navi />
  <SearchBox />

  <main>
    <div class="max-w-6xl mx-auto px-4 py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="flex flex-col items-start justify-center">
          <h1 class="text-3xl font-bold text-transparent mb-4 bg-gray-300 bg-clip-text">
            <img src="../logos/1.svg" alt="smile" class="w-12 h-12 inline-block mr-2">发现乐趣 享受快乐
          </h1>
          <h2 class="text-lg font-medium text-transparent mb-4 bg-gray-300 bg-clip-text leading-relaxed">
            实践、认识、再实践、再认识、这种结合现实规律和思想深度的形式，呈螺旋上升之势循环往复以至无穷</h2>
        </div>

        <div class="bg-zinc-800/50 backdrop-blur-md rounded-2xl p-6 border border-zinc-700">
          <h3 class="text-xl font-bold text-transparent bg-gray-300 bg-clip-text mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            关于本站
          </h3>
          <div class="space-y-3 text-gray-400 text-sm leading-relaxed">
            <p>🚀 这是一个专注于技术分享与资源汇总的个人网站，致力于为用户提供<span class="text-green-500 font-semibold">安全</span>、<span class="text-yellow-500 font-semibold">好用</span>、<span class="text-blue-500 font-semibold">有价值</span>的内容和实用资源。</p>
            <div class="grid grid-cols-2 gap-3 pt-2">
              <div class="flex items-center">
                <span class="w-2 h-2 rounded-full bg-teal-500 mr-2"></span>
                <span>游戏资源</span>
              </div>
              <div class="flex items-center">
                <span class="w-2 h-2 rounded-full bg-blue-500 mr-2"></span>
                <span>软件工具</span>
              </div>
              <div class="flex items-center">
                <span class="w-2 h-2 rounded-full bg-purple-500 mr-2"></span>
                <span>系统镜像</span>
              </div>
              <div class="flex items-center">
                <span class="w-2 h-2 rounded-full bg-amber-500 mr-2"></span>
                <span>技术博客</span>
              </div>
            </div>
          </div>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 pt-12 pb-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/game" class="group relative bg-zinc-800/50 backdrop-blur-md rounded-xl p-4 border border-zinc-700 hover:border-teal-500/50 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-teal-500/10">
          <div class="absolute inset-0 rounded-xl bg-linear-to-br from-teal-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="relative z-10 flex items-center">
            <div class="w-10 h-10 rounded-lg bg-teal-500/20 flex items-center justify-center mr-3 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-white group-hover:text-teal-200 transition-colors">游戏资源库</h3>
              <p class="text-gray-500 text-xs">实用修改器与工具</p>
            </div>
          </div>
        </a>

        <a href="/software" class="group relative bg-zinc-800/50 backdrop-blur-md rounded-xl p-4 border border-zinc-700 hover:border-blue-500/50 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-blue-500/10">
          <div class="absolute inset-0 rounded-xl bg-linear-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="relative z-10 flex items-center">
            <div class="w-10 h-10 rounded-lg bg-blue-500/20 flex items-center justify-center mr-3 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-white group-hover:text-blue-200 transition-colors">软件工具箱</h3>
              <p class="text-gray-500 text-xs">开发、设计、办公</p>
            </div>
          </div>
        </a>

        <a href="/system" class="group relative bg-zinc-800/50 backdrop-blur-md rounded-xl p-4 border border-zinc-700 hover:border-purple-500/50 transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-purple-500/10">
          <div class="absolute inset-0 rounded-xl bg-linear-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="relative z-10 flex items-center">
            <div class="w-10 h-10 rounded-lg bg-purple-500/20 flex items-center justify-center mr-3 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-white group-hover:text-purple-200 transition-colors">系统与激活</h3>
              <p class="text-gray-500 text-xs">系统镜像与激活工具</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </main>

  <Footer />
  <PerformanceOptimizer />
</BaseLayout>


