---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CategoryFilter from "../../components/CategoryFilter.astro";
import PerformanceOptimizer from "../../components/PerformanceOptimizer.astro";
import { getCollection, type CollectionEntry } from 'astro:content';

const gameItems: CollectionEntry<'game'>[] = await getCollection('game');
const categories: string[] = [...new Set(gameItems.map(item => item.data.category))];

const breadcrumbItems = [
  { label: '主页', href: '/' },
  { label: '单机游戏' }
];
---

<BaseLayout title="单机游戏 - Mped 的个人网站" description="浏览所有单机游戏推荐，包括动作、冒险、角色扮演、竞速和沙盒等多种类型。">
  <Navi />

  <main data-pagefind-body class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} />


      <div class="bg-transparent rounded-lg p-4 mb-4">
        <CategoryFilter categories={categories} baseUrl="/game" />
      </div>

      <div class="flex justify-between items-center mb-6">
        <p class="text-gray-400 whitespace-nowrap">
          找到 <span class="text-teal-400 font-semibold">{gameItems.length}</span> 个游戏
        </p>
        <p class="text-gray-400 text-sm whitespace-nowrap">
          当前分类：<span class="text-teal-400">全部</span>
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {gameItems.map(game => (
          <a
            href={`/game/${game.id}`}
            class="bg-zinc-800 rounded-xl p-3 border border-zinc-700 hover:border-teal-500/50 hover:scale-105 hover:shadow-2xl cursor-pointer block transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <div class="flex items-center mb-4">
                <div
                  class="w-20 h-10 rounded-lg flex items-center justify-center"
                  style={`background-color: ${game.data.color};`}
                >
                  <span class="text-white font-bold text-xl">{game.data.icon}</span>
                </div>
                <div class="ml-8">
                  <h3 class="text-base font-bold text-white hover:text-teal-300 transition-colors">{game.data.name}</h3>
                  <span class="text-sm text-gray-400">{game.data.category}</span>
                </div>
              </div>
              <span class="text-gray-300 text-xs grow mb-2 leading-relaxed">{game.data.description}</span>
              <div class="flex justify-between text-xs text-gray-400">
                <span class="bg-zinc-700 px-2 py-1 rounded">{game.data.genre}</span>
                <span>{game.data.releaseYear}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
  <PerformanceOptimizer />
</BaseLayout>
