---
import "../../styles/global.css";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CategoryFilter from "../../components/CategoryFilter.astro";
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const gameItems = await getCollection('game');
  const categories = [...new Set(gameItems.map(item => item.data.category))];
  
  return categories.map(category => {
    const slug = category.toLowerCase().replace(/\s+/g, '-');
    const filteredGame = gameItems.filter(item => item.data.category === category);
    
    return {
      params: { category: slug },
      props: { 
        category,
        filteredGame,
        allCategories: categories
      }
    };
  });
}

const { category, filteredGame, allCategories } = Astro.props;

const breadcrumbItems = [
  { label: '主页', href: '/' },
  { label: '游戏', href: '/game' },
  { label: category }
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={`浏览${category}类型的游戏。`} />
  <meta name="author" content="Mped" />
  <link rel="icon" href="/favicon.png" />
  <title>{category}游戏 - Mped 的个人网站</title>
</head>

<body class="flex flex-col min-h-screen">
  <Navi />

  <main class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} currentPage={category} />
      

      <div class="bg-zinc-900 rounded-lg p-6 mb-8">
        <CategoryFilter categories={allCategories} selectedCategory={category} baseUrl="/game" />
      </div>

      <div class="flex justify-between items-center mb-6">
        <p class="text-gray-400 whitespace-nowrap">
          找到 <span class="text-teal-400 font-semibold">{filteredGame.length}</span> 个游戏
        </p>
        <p class="text-gray-400 text-sm whitespace-nowrap">
          当前分类：<span class="text-teal-400">{category}</span>
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 w-full">
        {filteredGame.map(game => (
          <a 
            href={`/game/${game.id}`}
            class="game-card bg-zinc-800 rounded-xl p-6 hover:scale-105 hover:shadow-2xl transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <div class="flex items-center mb-4">
                <div 
                  class="w-12 h-12 rounded-lg flex items-center justify-center"
                  style={`background-color: ${game.data.color};`}
                >
                  <span class="text-white font-bold text-xl">{game.data.icon}</span>
                </div>
                <div class="ml-4">
                  <h3 class="text-lg font-bold text-white hover:text-teal-300 transition-colors">{game.data.name}</h3>
                  <span class="text-xs text-gray-400">{game.data.category}</span>
                </div>
              </div>
              <p class="text-gray-300 text-sm flex-grow mb-4 leading-relaxed">{game.data.description}</p>
              <div class="flex justify-between text-xs text-gray-400">
                <span class="bg-zinc-700 px-2 py-1 rounded">{game.data.genre}</span>
                <span>{game.data.releaseYear}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/game" class="inline-block px-8 py-3 bg-teal-500 text-white font-semibold rounded-lg hover:bg-teal-400 transition-colors">
          返回全部游戏
        </a>
      </div>
    </div>
  </main>

  <Footer />
</body>
</html>
