---
import "../../styles/global.css";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import PerformanceOptimizer from "../../components/PerformanceOptimizer.astro";
import { getEntry, render, getCollection, type CollectionEntry } from 'astro:content';

const { id } = Astro.params;

export async function getStaticPaths() {
  const gameItems: CollectionEntry<'game'>[] = await getCollection('game');
  return gameItems.map(game => ({
    params: { id: game.id },
  }));
}

const game: CollectionEntry<'game'> = await getEntry('game', id);

if (!game) {
  return new Response(null, {
    status: 404,
    headers: {
      Location: '/404'
    }
  });
}

const { Content } = await render(game);

const pageTitle = `${game.data.name} - 游戏详情 - Mped的个人网站`;
const pageDescription = `${game.data.name} - ${game.data.description}`;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={pageDescription} />
  <meta name="author" content="Mped" />
  <link rel="icon" href="/favicon.png" />
  <title>{pageTitle}</title>
</head>

<body class="flex flex-col min-h-screen">
  <Navi />

  <main class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <!-- 返回按钮 -->
      <div class="mb-6">
        <button onclick="history.back()" class="inline-flex items-center text-teal-400 hover:text-teal-300 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m0 0l6-6m-6 6l6 6"></path>
          </svg>
          <span>返回上一页</span>
        </button>
      </div>

      <div class="bg-zinc-800 rounded-xl p-8">
        <div class="flex items-center mb-6">
          <div
            class="w-16 h-16 rounded-lg flex items-center justify-center"
            style={`background-color: ${game.data.color};`}
          >
            <span class="text-white font-bold text-2xl">{game.data.icon}</span>
          </div>
          <div class="ml-4">
            <h1 class="text-3xl font-bold text-white mb-2">{game.data.name}</h1>
            <span class="text-sm text-gray-400">{game.data.category}</span>
          </div>
        </div>

        <div class="mb-6">
          <h2 class="text-l font-semibold text-white mb-4">游戏介绍</h2>
          <p class="text-gray-300 text-lg leading-relaxed">{game.data.description}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
          <div class="bg-zinc-700 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-white mb-3">游戏类型</h3>
            <p class="text-gray-300">{game.data.genre}</p>
          </div>
          <div class="bg-zinc-700 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-white mb-3">发行年份</h3>
            <p class="text-gray-300">{game.data.releaseYear}</p>
          </div>
          <div class="bg-zinc-700 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-white mb-3">游戏平台</h3>
            <p class="text-gray-300">{game.data.platform}</p>
          </div>
        </div>

        <div class="bg-zinc-900 rounded-lg p-8">
          <h2 class="text-xl font-semibold text-white mb-4">详细介绍</h2>
          <div class="prose prose-invert max-w-none text-gray-300">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <PerformanceOptimizer />
</body>
</html>