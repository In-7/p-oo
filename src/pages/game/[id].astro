---
import "../../styles/global.css";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import { getEntry, render, getCollection } from 'astro:content';

// 获取动态路由参数
const { id } = Astro.params;

// 获取所有游戏数据用于生成静态路径
export async function getStaticPaths() {
  const gameItems = await getCollection('game');
  return gameItems.map(game => ({
    params: { id: game.id },
  }));
}

// 获取单个游戏数据
const game = await getEntry('game', id);

// 如果游戏不存在，重定向到 404
if (!game) {
  return new Response(null, {
    status: 404,
    headers: {
      Location: '/404'
    }
  });
}

// 渲染 Markdown 内容
const { Content } = await render(game);

// 动态 SEO 配置
const pageTitle = `${game.data.name} - 游戏详情 - Mped的个人网站`;
const pageDescription = `${game.data.name} - ${game.data.description}`;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={pageDescription} />
  <meta name="author" content="Mped" />
  <link rel="icon" href="/favicon.png" />
  <title>{pageTitle}</title>
</head>

<body class="flex flex-col min-h-screen">
  <Navi />
  
  <main class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <!-- 返回按钮 -->
      <div class="mb-6">
        <a href="/game" class="inline-flex items-center text-teal-400 hover:text-teal-300 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 5 5v12a5 5 5 12a5 5 5 12a5 5 5-12"></path>
          </svg>
          <span>返回游戏列表</span>
        </a>
      </div>

      <!-- 游戏详情 -->
      <div class="bg-zinc-800 rounded-xl p-8">
        <!-- 游戏标题和分类 -->
        <div class="flex items-center mb-6">
          <div 
            class="w-16 h-16 rounded-lg flex items-center justify-center"
            style={`background-color: ${game.data.color};`}
          >
            <span class="text-white font-bold text-2xl">{game.data.icon}</span>
          </div>
          <div class="ml-4">
            <h1 class="text-3xl font-bold text-white mb-2">{game.data.name}</h1>
            <span class="text-sm text-gray-400">{game.data.category}</span>
          </div>
        </div>

        <!-- 游戏描述 -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-white mb-4">游戏介绍</h2>
          <p class="text-gray-300 text-lg leading-relaxed">{game.data.description}</p>
        </div>

        <!-- 游戏信息 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="bg-zinc-700 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-white mb-3">类型</h3>
            <p class="text-gray-300">{game.data.genre}</p>
          </div>
          <div class="bg-zinc-700 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-white mb-3">平台</h3>
            <p class="text-gray-300">{game.data.platform}</p>
          </div>
          <div class="bg-zinc-700 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-white mb-3">发行年份</h3>
            <p class="text-gray-300">{game.data.releaseYear}</p>
          </div>
        </div>

        <!-- Markdown 内容 -->
        <div class="bg-zinc-900 rounded-lg p-8">
          <h2 class="text-xl font-semibold text-white mb-4">详细信息</h2>
          <div class="prose prose prose-invert max-w-none text-gray-300">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</body>
</html>