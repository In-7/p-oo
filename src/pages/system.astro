---
import "../styles/global.css";
import Navi from "../components/Navi.astro";
import Footer from "../components/Footer.astro";

---

<!DOCTYPE html>
<html lang="zh-CN">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content="系统 - 青火的个人网站" />
        <meta name="keywords" content="系统, 系统, 系统" />
        <meta name="author" content="青火" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.png" />
    </head>
    <body class="flex flex-col min-h-screen bg-zinc-900">
        <Navi />
        <main class="flex-1 container mx-auto px-2 py-6">
            <div class="max-w-4xl mx-auto">
                <!-- 内容区域 -->
                <div class="space-y-8">
                    <!-- 介绍部分 -->
                    <div class="bg-zinc-800 rounded-lg p-6">
                        <h3 class="text-2xl font-semibold text-white mb-4">系统开发</h3>
                        <p class="text-gray-300 leading-relaxed mb-4">我正在学习 Astro 的入门教程。这是我网站上的第二个页面，也是我自己建立的第一页面！</p>
                        <p class="text-gray-400 text-sm">随着我完成更多教程，该站点将更新，所以请继续查看我的旅程将如何进行吧！</p>
                    </div>

                    <!-- 技术栈部分 -->
                    <div class="bg-zinc-800 rounded-lg p-6">
                        <h4 class="text-xl font-semibold text-white mb-4">技术栈</h4>
                        <div class="grid gap-4 md:grid-cols-2">
                            <div>
                                <h5 class="text-lg font-medium text-teal-300 mb-2">前端技术</h5>
                                <ul class="text-gray-300 space-y-1">
                                    <li>Astro</li>
                                    <li>Tailwind CSS</li>
                                    <li>TypeScript</li>
                                </ul>
                            </div>
                            <div>
                                <h5 class="text-lg font-medium text-teal-300 mb-2">开发工具</h5>
                                <ul class="text-gray-300 space-y-1">
                                    <li>VS Code</li>
                                    <li>Git</li>
                                    <li>Node.js</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <Footer />
    </body>
</html>
