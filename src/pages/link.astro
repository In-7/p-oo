---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navi from "../components/Navi.astro";
import Footer from "../components/Footer.astro";

interface LinkItem {
  name: string;
  url: string;
  desc: string;
  tags?: string[];
  icon?: string;
}

const links: LinkItem[] = [
  { name: "百度", url: "https://www.baidu.com", desc: "全球最大的中文搜索引擎", tags: ["搜索"], icon: "baidu" },
  { name: "Google", url: "https://www.google.com", desc: "全球最大的搜索引擎", tags: ["搜索"], icon: "google" },
  { name: "GitHub", url: "https://github.com", desc: "全球最大的代码托管平台", tags: ["开发"], icon: "github" },
  { name: "bilibili", url: "https://www.bilibili.com", desc: "国内知名的视频弹幕网站", tags: ["视频"], icon: "bilibili" },
  { name: "知乎", url: "https://www.zhihu.com", desc: "中文互联网最大的知识讨论平台", tags: ["社区"], icon: "zhihu" },
  { name: "掘金", url: "https://juejin.cn", desc: "面向全球开发者的技术社区", tags: ["社区"], icon: "juejin" },
  { name: "Stack Overflow", url: "https://stackoverflow.com", desc: "全球最大的程序员问答社区", tags: ["开发"], icon: "stackoverflow" },
  { name: "MDN", url: "https://developer.mozilla.org", desc: "Web开发者的必备参考文档", tags: ["文档"], icon: "mdnwebdocs" },
  { name: "Vite", url: "https://vitejs.dev", desc: "下一代前端开发与构建工具", tags: ["工具"], icon: "vite" },
  { name: "Tailwind CSS", url: "https://tailwindcss.com", desc: "utility-first CSS框架", tags: ["工具"], icon: "tailwindcss" },
  { name: "Astro", url: "https://astro.build", desc: "内容驱动的静态站点生成器", tags: ["框架"], icon: "astro" },
  { name: "Vue", url: "https://vuejs.org", desc: "渐进式JavaScript框架", tags: ["框架"], icon: "vuedotjs" },
  { name: "React", url: "https://react.dev", desc: "用于构建用户界面的JavaScript库", tags: ["框架"], icon: "react" },
  { name: "TypeScript", url: "https://www.typescriptlang.org", desc: "JavaScript的超集，支持类型系统", tags: ["语言"], icon: "typescript" },
  { name: "Node.js", url: "https://nodejs.org", desc: "基于Chrome V8引擎的JavaScript运行时", tags: ["运行时"], icon: "nodejs" },
  { name: "Deno", url: "https://deno.land", desc: "现代JavaScript和TypeScript运行时", tags: ["运行时"], icon: "deno" },
];

const allTags = [...new Set(links.flatMap(l => l.tags || []))].sort();
const linksByTag = allTags.reduce((acc, tag) => {
  acc[tag] = links.filter(l => l.tags?.includes(tag));
  return acc;
}, {} as Record<string, LinkItem[]>);
---

<BaseLayout title="导航页 - Mped 的个人网站" description="实用的网页导航，快速访问常用网站。">
  <Navi />

  <!-- 左侧分类导航 - 固定在页面左侧，手机端隐藏 -->
  <aside class="fixed left-0 top-24 z-40 pl-4 max-md:hidden">
    <div class="bg-zinc-800/80 backdrop-blur-sm rounded-r-xl border border-zinc-700 p-4">
      <h2 class="text-lg font-medium text-teal-400 mb-4">分类</h2>
      <ul class="space-y-2">
        {allTags.map((tag) => (
          <li>
            <a
              href={`#${tag}`}
              class="flex items-center justify-between px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-zinc-700/50 rounded-lg transition-colors"
            >
              <span>{tag}</span>
              <span class="text-xs text-gray-500 bg-zinc-700 px-2 py-0.5 rounded-full">
                {linksByTag[tag].length}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </aside>

  <div class="container mx-auto px-4 py-8">
    <section class="space-y-6">
      {allTags.map((tag) => (
        <div id={tag} class="scroll-mt-24">
          <h2 class="text-xl font-medium text-teal-400 mb-4 flex items-center gap-2">
            {tag}
            <span class="text-sm text-gray-500 font-normal">({linksByTag[tag].length})</span>
          </h2>
          <div class="grid gap-4 sm:gap-5 lg:gap-6" style="grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));">
            {linksByTag[tag].map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                title={link.desc}
                class="group relative aspect-square overflow-hidden flex flex-col items-center justify-center p-4 bg-zinc-800/50 rounded-2xl border border-zinc-700 hover:border-teal-500/50 hover:bg-zinc-800 transition-all duration-300 hover:shadow-lg hover:shadow-teal-500/10 hover:scale-105"
              >
                <div class="w-8 h-8 mb-2 flex items-center justify-center">
                  {link.icon ? (
                    <img
                      src={`https://cdn.simpleicons.org/${link.icon}`}
                      alt={`${link.name} Logo`}
                      class="max-w-full max-h-full object-contain"
                      onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex'`}
                    />
                  ) : null}
                  <span
                    class="w-8 h-8 hidden items-center justify-center text-sm font-bold text-zinc-400 bg-zinc-700 rounded"
                    style={link.icon ? "display:none" : "display:flex"}
                  >
                    {link.name[0]}
                  </span>
                </div>
                <h3 class="text-xs font-medium text-white group-hover:text-teal-400 transition-colors text-center truncate w-full px-1">
                  {link.name}
                </h3>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  </div>

  <Footer />
</BaseLayout>