---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navi from "../components/Navi.astro";
import Footer from "../components/Footer.astro";

interface LinkItem {
  name: string;
  url: string;
  desc: string;
  tags?: string[];
}

const links: LinkItem[] = [
  { name: "百度", url: "https://www.baidu.com", desc: "全球最大的中文搜索引擎", tags: ["搜索", "AI"] },
  { name: "Google", url: "https://www.google.com", desc: "全球最大的搜索引擎", tags: ["搜索"] },
  { name: "GitHub", url: "https://github.com", desc: "全球最大的代码托管平台", tags: ["开发", "开源"] },
  { name: "bilibili", url: "https://www.bilibili.com", desc: "国内知名的视频弹幕网站", tags: ["视频", "弹幕"] },
  { name: "知乎", url: "https://www.zhihu.com", desc: "中文互联网最大的知识讨论平台", tags: ["问答", "知识"] },
  { name: "掘金", url: "https://juejin.cn", desc: "面向全球开发者的技术社区", tags: ["技术", "社区"] },
  { name: "Stack Overflow", url: "https://stackoverflow.com", desc: "全球最大的程序员问答社区", tags: ["问答", "开发"] },
  { name: "MDN", url: "https://developer.mozilla.org", desc: "Web开发者的必备参考文档", tags: ["文档", "Web"] },
  { name: "Vite", url: "https://vitejs.dev", desc: "下一代前端开发与构建工具", tags: ["工具", "前端"] },
  { name: "Tailwind CSS", url: "https://tailwindcss.com", desc: "utility-first CSS框架", tags: ["CSS", "前端"] },
  { name: "Astro", url: "https://astro.build", desc: "内容驱动的静态站点生成器", tags: ["框架", "静态"] },
  { name: "Vue", url: "https://vuejs.org", desc: "渐进式JavaScript框架", tags: ["框架", "前端"] },
  { name: "React", url: "https://react.dev", desc: "用于构建用户界面的JavaScript库", tags: ["框架", "前端"] },
  { name: "TypeScript", url: "https://www.typescriptlang.org", desc: "JavaScript的超集，支持类型系统", tags: ["语言", "前端"] },
  { name: "Node.js", url: "https://nodejs.org", desc: "基于Chrome V8引擎的JavaScript运行时", tags: ["后端", "运行时"] },
  { name: "Deno", url: "https://deno.land", desc: "现代JavaScript和TypeScript运行时", tags: ["后端", "运行时"] },
];
---

<BaseLayout title="导航页 - Mped 的个人网站" description="实用的网页导航，快速访问常用网站。">
  <Navi />

  <main class="container mx-auto px-4 py-8">
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
      {links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col items-center p-4 bg-zinc-800/50 rounded-xl border border-zinc-700 hover:border-teal-500/50 hover:bg-zinc-800 transition-all duration-300 hover:shadow-lg hover:shadow-teal-500/10 hover:-translate-y-1"
        >
          <div class="w-12 h-12 mb-3 rounded-lg bg-white/5 p-2 flex items-center justify-center">
            <img
              src={`https://www.google.com/s2/favicons?domain=${new URL(link.url).hostname}&sz=64`}
              alt={`${link.name} Logo`}
              class="w-full h-full object-contain"
              onerror={`this.src='data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23666"><text y="20" font-size="20">${link.name[0]}</text></svg>'`}
            />
          </div>

          <h3 class="text-sm font-medium text-white group-hover:text-teal-400 transition-colors text-center truncate w-full">
            {link.name}
          </h3>

          <p class="text-xs text-gray-500 group-hover:text-gray-400 transition-colors text-center mt-1 line-clamp-2 w-full">
            {link.desc}
          </p>

          <div class="absolute inset-0 rounded-xl border-2 border-transparent group-hover:border-teal-500/20 pointer-events-none transition-all duration-300"></div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>
