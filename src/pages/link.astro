		<link rel="canonical" href={Astro.url.href} />
		<title>Mped的个人网站 - 分享优质网页链接</title>
				<!-- 结构化数据 -->
		<script type="application/ld+json">
		{
		  "@context": "https://schema.org",
		  "@type": "WebSite",
		  "name": "Mped的个人网站",
		  "description": "分享优质网页链接",
		  "url": "https://mped.netlify.app/",
		  "author": {
		    "@type": "Person",
		    "name": "Mped"
		  },
		  "inLanguage": "zh-CN"
		}
		</script>
	</head>
    <body>


        <Navi />
        <Footer />
    </body>
</html>

