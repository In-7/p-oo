---
import "../styles/global.css";
import Navi from "../components/Navi.astro";
import Footer from "../components/Footer.astro";
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>页面未找到 - 404</title>
    <meta name="description" content="抱歉，您访问的页面不存在" />
  </head>
  <body class="flex flex-col min-h-screen bg-zinc-900">
    <Navi />
    <main class="flex-1 grid place-items-center px-6 pt-32 pb-24 sm:pt-18 sm:pb-36 lg:px-8">
      <div class="text-center max-w-md">
        <!-- 404图标 -->
        <div class="mb-8">
          <span class="text-8xl font-bold text-teal-400">404</span>
        </div>
        
        <!-- 错误信息 -->
        <div class="bg-zinc-800 rounded-lg p-8 mb-8">
          <h1 class="text-3xl font-bold text-white mb-4">页面走丢啦</h1>
          <p class="text-gray-300">抱歉，您访问的页面不存在或已被移动。</p>
        </div>
        
        <!-- 操作按钮 -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="inline-flex items-center justify-center px-6 py-3 bg-teal-500 text-white font-semibold rounded-lg hover:bg-teal-400 transition-colors">
            返回首页
          </a>
          <a href="/blog" class="inline-flex items-center justify-center px-6 py-3 bg-zinc-700 text-gray-300 font-semibold rounded-lg hover:bg-zinc-600 transition-colors">
            查看博客 <span class="ml-2">→</span>
          </a>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>