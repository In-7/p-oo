---
import "../../styles/global.css";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import PerformanceOptimizer from "../../components/PerformanceOptimizer.astro";
import { getEntry, render, getCollection, type CollectionEntry } from 'astro:content';

// 获取动态路由参数
const { id } = Astro.params;

// 获取所有软件数据用于生成静态路径
export async function getStaticPaths() {
  const softwareItems: CollectionEntry<'software'>[] = await getCollection('software');
  return softwareItems.map(software => ({
    params: { id: software.id },
  }));
}

// 获取单个软件数据
const software: CollectionEntry<'software'> = await getEntry('software', id);

// 如果软件不存在，重定向到 404
if (!software) {
  return new Response(null, {
    status: 404,
    headers: {
      Location: '/404'
    }
  });
}

// 渲染 Markdown 内容
const { Content } = await render(software);

// 动态 SEO 配置
const pageTitle = `${software.data.name} - 软件详情 - Mped的个人网站`;
const pageDescription = `${software.data.name} - ${software.data.description}`;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={pageDescription} />
  <meta name="author" content="Mped" />
  <link rel="icon" href="/favicon.svg" />
  <title>{pageTitle}</title>
</head>

<body class="flex flex-col min-h-screen">
  <Navi />
  
  <main class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <!-- 返回按钮 -->
      <div class="mb-6">
        <button onclick="history.back()" class="inline-flex items-center text-teal-400 hover:text-teal-300 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m0 0l6-6m-6 6l6 6"></path>
          </svg>
          <span>返回上一页</span>
        </button>
      </div>

      <!-- 软件详情 -->
      <div class="bg-zinc-800 rounded-xl p-8">
        <!-- 软件标题和分类 + 价格平台右上角 -->
        <div class="flex items-start justify-between mb-6">
          <div class="flex items-center">
            <div 
              class="w-16 h-16 rounded-lg flex items-center justify-center"
              style={`background-color: ${software.data.color};`}
            >
              <span class="text-white font-bold text-2xl">{software.data.icon}</span>
            </div>
            <div class="ml-4">
              <h1 class="text-3xl font-bold text-white mb-2">{software.data.name}</h1>
              <span class="text-sm text-gray-400">{software.data.category}</span>
            </div>
          </div>
          <!-- 价格平台右上角小卡片 -->
          <div class="flex gap-3">
            <div class="bg-zinc-700 rounded-lg px-4 py-3 text-center min-w-24">
              <h3 class="text-xs font-semibold text-gray-400 mb-1">价格</h3>
              <p class="text-gray-200 text-sm">{software.data.price}</p>
            </div>
            <div class="bg-zinc-700 rounded-lg px-4 py-3 text-center min-w-24">
              <h3 class="text-xs font-semibold text-gray-400 mb-1">平台</h3>
              <p class="text-gray-200 text-sm">{software.data.platform}</p>
            </div>
          </div>
        </div>

        <!-- 软件描述 -->
        <div class="mb-8">
          <p class="text-gray-400 text-sm leading-relaxed">{software.data.description}</p>
        </div>

        <!-- Markdown 内容 -->
        <div class="bg-zinc-900 rounded-lg p-8">
          <h2 class="text-xl font-semibold text-white mb-4">详细信息</h2>
          <div class="prose prose prose-invert max-w-none text-gray-300">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
  <PerformanceOptimizer />
</body>
</html>