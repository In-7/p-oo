---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navi from "../../components/Navi.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CategoryFilter from "../../components/CategoryFilter.astro";
import PerformanceOptimizer from "../../components/PerformanceOptimizer.astro";
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const softwareItems: CollectionEntry<'software'>[] = await getCollection('software');
  const categories: string[] = [...new Set(softwareItems.map(item => item.data.category))];

  return categories.map(category => {
    const slug = category.toLowerCase().replace(/\s+/g, '-');
    const filteredSoftware: CollectionEntry<'software'>[] = softwareItems.filter(item => item.data.category === category);

    return {
      params: { category: slug },
      props: {
        category,
        filteredSoftware,
        allCategories: categories
      }
    };
  });
}

const { category, filteredSoftware, allCategories } = Astro.props;

const breadcrumbItems = [
  { label: '主页', href: '/' },
  { label: '软件工具', href: '/software' },
  { label: category }
];
---

<BaseLayout title={`${category} - Mped 的个人网站`} description={`浏览${category}分类下的软件工具和应用程序。`}>
  <Navi />

  <main data-pagefind-body class="flex-1 container mx-auto px-2 py-6">
    <div class="max-w-4xl mx-auto">
      <Breadcrumbs items={breadcrumbItems} currentPage={category} />

      <div class="bg-transparent rounded-lg p-4 mb-4">
        <CategoryFilter categories={allCategories} selectedCategory={category} baseUrl="/software" />
      </div>

      <div class="flex justify-between items-center mb-6">
        <p class="text-gray-400 whitespace-nowrap">
          找到 <span class="text-teal-400 font-semibold">{filteredSoftware.length}</span> 个软件
        </p>
        <p class="text-gray-400 text-xs whitespace-nowrap">
          当前分类：<span class="text-teal-400">{category}</span>
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {filteredSoftware.map(software => (
          <a
            href={`/software/${software.id}`}
            class="software-card bg-zinc-800 rounded-xl p-3 hover:scale-105 hover:shadow-2xl cursor-pointer block transition-all duration-300"
          >
            <div class="flex flex-col h-full">
              <div class="flex items-center mb-4">
                <div
                  class="w-20 h-10 rounded-lg flex items-center justify-center"
                  style={`background-color: ${software.data.color};`}
                >
                  <span class="text-white font-bold text-xl">{software.data.icon}</span>
                </div>
                <div class="ml-8">
                  <h3 class="text-base font-bold text-white hover:text-teal-300 transition-colors">{software.data.name}</h3>
                  <span class="text-sm text-gray-400">{software.data.category}</span>
                </div>
              </div>
              <span class="text-gray-300 text-xs grow mb-2 leading-relaxed">{software.data.description}</span>
              <div class="flex justify-between text-xs text-gray-400">
                <span class="bg-zinc-700 px-2 py-1 rounded">{software.data.price}</span>
                <span>{software.data.platform}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/software" class="inline-block px-8 py-3 bg-teal-500 text-white font-semibold rounded-lg hover:bg-teal-400 transition-colors">
          返回全部软件
        </a>
      </div>
    </div>
  </main>

  <Footer />
  <PerformanceOptimizer />
</BaseLayout>
